# ===========================================================================
# GASA — variables de entorno (plantilla)
# Copia este fichero a `.env` y rellena los valores. `.env` está en .gitignore.
# NUNCA commitees credenciales reales.
# ===========================================================================

# --- Backend de estado (Supabase / Postgres) ---------------------------------
# Proyecto Supabase que aloja el estado del juego (candidato, logro, diagnostico).
# La clave anónima (anon/publishable) es segura para el cliente PORQUE el acceso
# está protegido por Row-Level Security (ver supabase/README.md y §4.2 del PRD).
PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# La service_role key (rol de profesor) NUNCA va en el cliente ni en el repo.
# Úsala solo en herramientas administrativas locales del profesor.
# SUPABASE_SERVICE_ROLE_KEY=...

# --- Despliegue (GitHub Pages) ----------------------------------------------
# Para GitHub Pages de proyecto, BASE_PATH = "/<nombre-del-repo>".
SITE_URL=https://alexcatesp.github.io
BASE_PATH=/iesgalileo_2627
